# ===========================
# API Keys (복사 후 .env로 저장, .env는 gitignore됨)
# cp .env.example .env 후 실제 키 입력
# ===========================

# OpenAI (GPT, Whisper, DALL-E — 뉴스/커뮤니티 기능)
OPENAI_API_KEY=

# Google Gemini + Imagen (지식숏폼 기능)
# https://aistudio.google.com/app/apikey 에서 발급
GEMINI_API_KEY=

# NewsAPI (newsapi.org)
NEWS_API_KEY=

# Pexels (pexels.com/api) - 뉴스 멀티미디어 검색
PEXELS_API_KEY=

# Reddit (선택)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ===========================
# DB / 인프라 (기본값 있음, 필요시 덮어씀)
# ===========================
# DB_USERNAME=shortform
# DB_PASSWORD=shortform1234
# REDIS_HOST=localhost
# REDIS_PORT=16379
# RABBITMQ_HOST=localhost
# RABBITMQ_PORT=5672
