# Backend API
BACKEND_URL=http://localhost:8080

# RabbitMQ (Spring Boot 메시지 소비용)
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_RENDER_QUEUE=render.queue
RABBITMQ_PREVIEW_QUEUE=preview.queue
RABBITMQ_EXCHANGE=shortform.exchange

# Redis (Celery 내부 브로커)
REDIS_URL=redis://localhost:6379/0

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=shortform
MINIO_SECURE=false

# OpenAI Whisper
WHISPER_MODEL=base
# Options: tiny, base, small, medium, large

# Worker
WORKER_TEMP_DIR=./temp
WORKER_OUTPUT_DIR=./output
WORKER_CONCURRENCY=2

# Logging
LOG_LEVEL=INFO
